# Telegram Bot配置
# 从 @BotFather 获取您的 Bot Token
BOT_TOKEN=your_bot_token_here

# 您的话题群组ID (超级群组)
# 将机器人设为群组管理员后，在群组里发送 /getid
FORUM_GROUP_ID=-1001234567890

# 管理员ID（您的Telegram用户ID），多个ID用逗号分隔
ADMIN_IDS=123456789,987654321

# ============================================
# AI 配置
# ============================================

# Gemini API配置 (从 Google AI Studio 获取)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# OpenAI API配置 (可选，兼容API)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 是否启用AI自动识别垃圾信息和恶意内容
ENABLE_AI_FILTER=true

# AI判断的置信度阈值（0-100）
AI_CONFIDENCE_THRESHOLD=70

# ============================================
# 功能开关
# ============================================

# 是否启用新用户人机验证
VERIFICATION_ENABLED=true

# 是否启用黑名单用户自动解封机制
AUTO_UNBLOCK_ENABLED=true

# 是否启用RSS订阅
RSS_ENABLED=true

# 是否启用网络测试
NETWORK_TEST_ENABLED=true

# ============================================
# 数据库配置
# ============================================

# 数据库文件路径
DATABASE_PATH=./data/bot.db

# ============================================
# 性能配置
# ============================================

# 消息队列处理的worker数量
MAX_WORKERS=5

# 队列中消息的超时时间（秒）
QUEUE_TIMEOUT=30

# ============================================
# 验证配置
# ============================================

# 人机验证的超时时间（秒）
VERIFICATION_TIMEOUT=300

# 用户最大尝试验证次数
MAX_VERIFICATION_ATTEMPTS=3

# ============================================
# 速率限制
# ============================================

# Bot每分钟最大处理消息数（每个用户）
MAX_MESSAGES_PER_MINUTE=30

# ============================================
# RSS配置
# ============================================

# RSS数据文件路径
RSS_DATA_FILE=./data/rss_subscriptions.json

# RSS检查间隔（秒）
RSS_CHECK_INTERVAL=300

# 授权使用RSS功能的用户ID，逗号分隔
RSS_AUTHORIZED_USER_IDS=123456789

# ============================================
# 网络测试配置
# ============================================

# 远程服务器地址（用于网络测试）
REMOTE_SSH_HOST=
REMOTE_SSH_PORT=22
REMOTE_SSH_USER=
REMOTE_SSH_KEY_PATH=

# ============================================
# 日志配置
# ============================================

# 日志级别: trace, debug, info, warn, error
RUST_LOG=info
